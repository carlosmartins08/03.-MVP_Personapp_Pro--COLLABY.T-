{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "backend:dev": "npm --prefix backend run dev",
    "backend:test": "npm --prefix backend run test",
    "qa:checklist": "node scripts/qa-checklist.js",
    "qa:prep": "node scripts/qa-prep.js",
    "qa:validate-env": "node scripts/validate-env.js",
    "qa:start": "concurrently --kill-others-on-fail \"npm run backend:dev\" \"npm run dev\"",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "backend:bootstrap": "npm --prefix backend install && npm --prefix backend run prisma:generate && npm --prefix backend run prisma:migrate && npm --prefix backend run seed",
    "bootstrap": "npm run db:up && npm run backend:bootstrap",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "test": "vitest run",
    "lint": "eslint .",
    "preview": "vite preview"
  },
